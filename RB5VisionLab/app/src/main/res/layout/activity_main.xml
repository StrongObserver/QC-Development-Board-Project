<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Enhanced result. Drawn before textView/button so they overlay on top.
         Fills from the top down to the button so the image is large. -->
    <ImageView
        android:id="@+id/sr_result"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/control_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#99000000"
        android:padding="12dp"
        android:text="Hello World!"
        android:textColor="#FFFFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <HorizontalScrollView
        android:id="@+id/control_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="#66000000"
        android:fillViewport="false"
        android:padding="4dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/real_camera_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:minHeight="0dp"
                android:text="真实相机证据" />

            <Button
                android:id="@+id/sr_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:minHeight="0dp"
                android:text="超分测试图 (CPU)" />

            <Button
                android:id="@+id/save_sample_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:minHeight="0dp"
                android:text="保存样张 / 长按高分辨率" />

            <Button
                android:id="@+id/qnn_fixed_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:minHeight="0dp"
                android:text="QNN 固定样张" />

            <Button
                android:id="@+id/offline_eval_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:minHeight="0dp"
                android:text="离线评测样张" />

        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
